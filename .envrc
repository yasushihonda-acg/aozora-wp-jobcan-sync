# catchup-setup: configured by project-setup skill
# Project: aozora-wp-jobcan-sync
# GitHub: yasushihonda-acg (ACG account)
# GCP:    aozora-wp-jobcan-sync (yasushi.honda@aozora-cg.com)

# Switch gh CLI to the ACG account for git push + gh api operations.
gh auth switch --user yasushihonda-acg 2>/dev/null || true
export GH_TOKEN=$(gh auth token)

# Activate the project-specific gcloud named configuration.
# This isolates account + project from other directories so `cd` automatically
# selects the right ACG context without polluting global gcloud state.
export CLOUDSDK_ACTIVE_CONFIG_NAME=aozora-wp-jobcan-sync
